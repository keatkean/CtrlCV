# Default: auto-detect text files and normalize line endings to LF in the repo.
* text=auto

# Source code — always LF in repo, native on checkout.
*.cs    text eol=lf diff=csharp
*.csproj text eol=lf
*.sln   text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.pubxml text eol=lf

# Binaries — never touch line endings.
*.exe   binary
*.dll   binary
*.ico   binary
*.png   binary
*.gif   binary
*.jpg   binary
*.jpeg  binary
*.db    binary
